#!/bin/sh
# presguel-apply-layout — presguel 의 베이스 키보드 레이아웃을 시스템에 적용한다.
#
# GNOME/Wayland 에서 ibus 엔진이 활성일 때 쓰는 XKB 레이아웃(=단축키·keysym 변환 기준)은
# 컴포넌트 XML 의 <layout>/<layout_variant> 가 결정한다(research/07). 이 파일은
# /usr/share/ibus/component (root 전용)에 있으므로, 설정창은 pkexec 로 이 스크립트를
# root 권한으로 호출해 레이아웃을 바꾼다.
#
# 사용법:  pkexec presguel-apply-layout <layout> [variant]
#   예) presguel-apply-layout us dvorak     # 단축키를 드보락 자리로
#       presguel-apply-layout us            # 평범한 QWERTY
set -eu

layout="${1:?usage: presguel-apply-layout <layout> [variant]}"
variant="${2:-}"

# 안전성: XKB 레이아웃/변형 이름에 허용되는 문자만(셸/XML 주입 방지).
case "$layout" in
    "" | *[!a-z0-9_+-]*) echo "invalid layout: $layout" >&2; exit 2 ;;
esac
case "$variant" in
    *[!a-z0-9_-]*) echo "invalid variant: $variant" >&2; exit 2 ;;
esac

comp="/usr/share/ibus/component/presguel.xml"
bin="/usr/local/bin/presguel-ibus"
setup="/usr/local/bin/presguel-setup"

# variant 가 있으면 <layout_variant> 줄을 넣는다.
variant_line=""
if [ -n "$variant" ]; then
    variant_line="
      <layout_variant>${variant}</layout_variant>"
fi

# 컴포넌트 XML 전체를 재생성(견고: 부분 sed 편집보다 안전).
cat > "$comp" <<XML
<?xml version="1.0" encoding="utf-8"?>
<component>
  <name>org.freedesktop.IBus.Presguel</name>
  <description>Presguel Korean Input Method</description>
  <exec>${bin} --ibus</exec>
  <version>0.1.0</version>
  <author>lens0021 &lt;lorentz0021@gmail.com&gt;</author>
  <license>LicenseRef-AllRightsReserved</license>
  <homepage>https://github.com/lens0021/presguel</homepage>
  <textdomain>presguel</textdomain>
  <engines>
    <engine>
      <name>presguel</name>
      <language>ko</language>
      <icon>ibus-hangul</icon>
      <layout>${layout}</layout>${variant_line}
      <longname>Presguel</longname>
      <description>Presguel 한글 입력기</description>
      <rank>50</rank>
      <symbol>가</symbol>
      <setup>${setup}</setup>
    </engine>
  </engines>
</component>
XML

# 시스템 레지스트리 캐시 갱신(엔진 desc 의 새 layout 을 ibus 가 읽도록).
ibus write-cache --system 2>/dev/null || true

echo "presguel: 베이스 레이아웃을 '${layout}${variant:+(${variant})}' 로 적용했습니다."
echo "로그아웃 후 다시 로그인하면 GNOME 이 새 레이아웃을 반영합니다."
